        // Renderizar Lista General de la Agenda con Filtros y Buscador
        function renderAgenda() {
            const listContainer = document.getElementById('agenda-list');
            listContainer.innerHTML = '';

            const filtered = AGENDA_DATA.filter(session => {
                // Filtro por periodo horario
                if (currentFilter === 'morning' && session.period !== 'morning') return false;
                if (currentFilter === 'afternoon' && session.period !== 'afternoon') return false;

                // Filtro de búsqueda
                if (searchQuery.trim() !== '') {
                    const query = searchQuery.toLowerCase();
                    const titleMatch = session.title.toLowerCase().includes(query);
                    const participantsMatch = session.participants.toLowerCase().includes(query);
                    const briefMatch = session.brief.toLowerCase().includes(query);
                    const bulletMatch = session.bullets.some(b => b.toLowerCase().includes(query));
                    return titleMatch || participantsMatch || briefMatch || bulletMatch;
                }

                return true;
            });

            if (filtered.length === 0) {
                listContainer.innerHTML = `
                    <div class="text-center py-12 border border-dashed border-stone-300 rounded-2xl bg-white">
                        <p class="text-slate-400 text-sm font-semibold">No se encontraron sesiones que coincidan con la búsqueda.</p>
                    </div>
                `;
                return;
