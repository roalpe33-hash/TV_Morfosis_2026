        // Marcar/Desmarcar Favorito
        function toggleFavorite(sessionId, event) {
            if (event) event.stopPropagation();

            const index = favorites.indexOf(sessionId);
            let added = false;
            if (index > -1) {
                favorites.splice(index, 1);
            } else {
                favorites.push(sessionId);
                added = true;
            }

            localStorage.setItem('tvm_favorites', JSON.stringify(favorites));
            updateFavBadges();

            // Mostrar toast
            const sessionTitle = AGENDA_DATA.find(s => s.id === sessionId)?.title;
            const shortTitle = sessionTitle ? (sessionTitle.substring(0, 30) + '...') : 'Sesión';
            showToast(added ? `Agregada a mi agenda: ${shortTitle}` : `Quitada de mi agenda: ${shortTitle}`);

            // Refrescar las listas
            if (currentTab === 'programa') renderAgenda();
            if (currentTab === 'favoritos') renderFavorites();
        }

        // Actualizar indicadores visuales de favoritos en cabecera
        function updateFavBadges() {
            const badge = document.getElementById('fav-badge');
            if (favorites.length > 0) {
                badge.innerText = favorites.length;
                badge.classList.remove('hidden');
            } else {
                badge.classList.add('hidden');
            }
        }

        // Mostrar Toast Customizado
        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-message').innerText = message;
            
            // Animación Entrada
            toast.classList.remove('translate-y-20', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');

            setTimeout(() => {
                // Animación Salida
                toast.classList.remove('translate-y-0', 'opacity-100');
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }

        // Modales - Abrir Ficha Detallada
        function openModal(sessionId) {
            const session = AGENDA_DATA.find(s => s.id === sessionId);
            if (!session) return;

            activeModalSessionId = sessionId;
            document.getElementById('modal-time').innerText = `${session.time} — Bloque ${session.period === 'morning' ? 'Mañana' : 'Tarde'}`;
            document.getElementById('modal-title').innerText = session.title;
            document.getElementById('modal-participants').innerText = session.participants;

            const bulletsContainer = document.getElementById('modal-bullets');
            bulletsContainer.innerHTML = '';
            session.bullets.forEach(bullet => {
                const li = document.createElement('li');
                li.className = "flex gap-2.5 items-start leading-relaxed";
                li.innerHTML = `
                    <span class="w-2 h-2 rounded-full bg-slate-800 mt-1.5 flex-shrink-0"></span>
                    <span>${bullet}</span>
                `;
                bulletsContainer.appendChild(li);
            });

            // Ajustar estado botón de favorito en modal
            const isFav = favorites.includes(sessionId);
            const favBtn = document.getElementById('modal-fav-btn');
            const favIcon = document.getElementById('modal-fav-icon');

            if (isFav) {
                favBtn.className = "px-4 py-2.5 bg-rose-50 text-slate-800 font-bold text-xs rounded-xl border border-rose-100 transition flex items-center gap-2";
                favBtn.querySelector('span').innerText = "Quitar de mi agenda";
                favIcon.className = "w-4 h-4 fill-rose-500 text-rose-500";
            } else {
                favBtn.className = "px-4 py-2.5 bg-white hover:bg-stone-100 text-slate-700 font-bold text-xs rounded-xl border border-stone-200 transition flex items-center gap-2";
                favBtn.querySelector('span').innerText = "Añadir a mi agenda";
                favIcon.className = "w-4 h-4 text-slate-400";
            }

            // Mostrar Modal
            const modal = document.getElementById('session-modal');
            modal.classList.remove('hidden');
        }

        // Modales - Cerrar
        function closeModal() {
            document.getElementById('session-modal').classList.add('hidden');
            activeModalSessionId = null;
        }

        // Favoritos desde Modal
        function toggleFavFromModal() {
            if (!activeModalSessionId) return;
            toggleFavorite(activeModalSessionId, null);
            // Re-abrir para refrescar el estado del botón
            openModal(activeModalSessionId);
        }


        // ================= CHATBOT SIMULADO (IA DE CONSULTA) =================
        function handleChatSubmit(e) {
            e.preventDefault();
            const input = document.getElementById('chat-input');
            const text = input.value.trim();
            if (text === '') return;

            addChatMessage('user', text);
            input.value = '';

            setTimeout(() => {
                const botResponse = generateBotResponse(text);
                addChatMessage('bot', botResponse);
            }, 600);
        }

        function askBot(pregunta) {
            changeTab('asistente');
            addChatMessage('user', pregunta);
            setTimeout(() => {
                const respuesta = generateBotResponse(pregunta);
                addChatMessage('bot', respuesta);
            }, 600);
        }

        function addChatMessage(sender, text) {
            const container = document.getElementById('chat-messages');
            const messageDiv = document.createElement('div');
            
            if (sender === 'user') {
                messageDiv.className = "flex gap-3 justify-end ml-auto max-w-[85%]";
                messageDiv.innerHTML = `
                    <div class="bg-slate-900 text-white px-4 py-3 rounded-2xl rounded-tr-none text-xs sm:text-sm font-medium leading-relaxed shadow-sm">
                        ${text}
                    </div>
                `;
            } else {
                messageDiv.className = "flex gap-3 max-w-[85%]";
                messageDiv.innerHTML = `
                    <div class="w-8 h-8 rounded-lg bg-slate-950 text-white flex items-center justify-center flex-shrink-0 text-xs font-bold shadow-sm">
                        TV
                    </div>
                    <div class="bg-white border border-stone-200 text-slate-700 px-4 py-3 rounded-2xl rounded-tl-none text-xs sm:text-sm shadow-sm leading-relaxed">
                        ${text}
                    </div>
                `;
            }

            container.appendChild(messageDiv);
            container.scrollTop = container.scrollHeight;
        }

        function clearChat() {
            const container = document.getElementById('chat-messages');
            container.innerHTML = '';
            addChatMessage('bot', 'Historial limpio. ¿En qué más puedo ayudarte acerca de las jornadas de TVmorfosis?');
        }

        // Generador de respuestas inteligentes sobre el dossier actual de IA
        function generateBotResponse(query) {
            const text = query.toLowerCase();

            if (text.includes('verificación') || text.includes('fake news') || text.includes('desinformación') || text.includes('fact-checking')) {
                return `La verificación se tratará en profundidad por la mañana en la <strong>Mesa Redonda 1: "El Periodista Aumentado" (de 11:00 a 12:15)</strong>. En ella, profesionales en activo compartirán cómo utilizan el software de IA para la verificación rápida de fuentes, metadatos e imágenes manipuladas en tiempo real.`;
            }
            if (text.includes('local') || text.includes('proximidad') || text.includes('regional')) {
                return `La aplicación en medios de proximidad se debatirá en la <strong>Mesa Redonda 2: "Eficiencia y Proximidad" (de 12:15 a 13:30)</strong>. Se analizará cómo las televisiones locales optimizan sus recursos limitados aplicando IA para tareas automatizadas de transcripción, subtitulados en lenguas cooficiales y distribución ágil.`;
            }
            if (text.includes('futuro') || text.includes('ingeniería') || text.includes('laboratorios') || text.includes('academia') || text.includes('científicos')) {
                return `La investigación de vanguardia se concentra en la <strong>Mesa Redonda 4: "La Frontera del Conocimiento" (de 16:45 a 18:00)</strong>. Participarán científicos de datos e ingenieros de IA debatiendo sobre el horizonte de los próximos 2 a 5 años (vídeo sintético ético, modelos predictivos y formación híbrida).`;
            }
            if (text.includes('organizan') || text.includes('universidad') || text.includes('atei')) {
                return `Las jornadas están organizadas conjuntamente por la <strong>Universitat de València</strong> (taller d'Audiovisuals) y la Asociación de Televisiones Educativas y Culturales Iberoamericanas (<strong>ATEI</strong>). La bienvenida oficial se realiza a las 09:00.`;
            }
            if (text.includes('entrevista') || text.includes('conferencia inicial') || text.includes('estado del arte')) {
                return `La jornada abre con una <strong>Conferencia Inicial en formato de entrevista ágil (de 09:30 a 10:30)</strong>. Un periodista de renombre conversará con un especialista sobre herramientas ya operativas en el mercado y las primeras lecciones organizativas de la transición.`;
            }
            if (text.includes('estrategia') || text.includes('corporativa') || text.includes('alianza') || text.includes('escala')) {
                return `Los planes a nivel organizativo y corporativo se tratarán en la <strong>Mesa Redonda 3: "Estrategias de Escala" (de 15:30 a 16:45)</strong>. Se centrará en el papel de redes como ATEI para crear alianzas internacionales e implantar modelos lingüísticos especializados en español.`;
            }
            if (text.includes('archivo') || text.includes('documentación') || text.includes('catalogar')) {
                return `La catalogación y rescate de patrimonio mediante IA se abordará en la <strong>Mesa Redonda 1 (de 11:00 a 12:15)</strong>, donde se presentarán casos reales de transcripción e indexación desasistida mediante visión por computador.`;
            }
            if (text.includes('horario') || text.includes('agenda') || text.includes('programa')) {
                return `La jornada se divide en un bloque de mañana (de 09:00 a 13:30, que incluye Inauguración, Entrevista Inicial y las Mesas Redondas 1 y 2) y un bloque de tarde (de 15:30 a 18:30, con las Mesas Redondas 3 y 4, seguido por las Conclusiones y Clausura).`;
            }

            return `Este encuentro de TVmorfosis València está plenamente enfocado en la <strong>aplicación práctica de la IA</strong> (redacción de temas, investigación de datos, verificación sistemática de desinformación y catalogación de archivos). Te recomiendo buscar mesas específicas en la sección "Programa" o revisar las fichas en detalle.`;
        }

        // Inicializar Estado al Cargar
        window.onload = function() {
            updateFavBadges();
            renderAgenda();
        }
    </script>
</body>
