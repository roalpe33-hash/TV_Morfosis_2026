<!DOCTYPE html>
<html lang="es" class="h-full bg-stone-50 text-slate-950">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TVmorfosis València - Guía Interactiva</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        tvm: {
                            yellow: '#f3c742',
                            orange: '#e67e22',
                            pink: '#e84393',
                            green: '#2ecc71',
                            blue: '#0984e3',
                            purple: '#6c5ce7',
                            dark: '#1e272e',
                            light: '#fcfcfc'
                        }
                    }
                }
            }
        }
    </script>
    <!-- Google Fonts: Elegant Serif for headings and clean Sans for UI -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #faf9f6; /* Soft paper white */
        }
        .serif-title {
            font-family: 'Playfair Display', serif;
            letter-spacing: -0.02em;
        }
        /* Custom Scrollbar styled for the bright layout */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f0ea;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>
<body class="flex flex-col min-h-screen text-slate-800">

    <!-- Notificación Custom -->
    <div id="toast" class="fixed bottom-5 right-5 z-50 transform translate-y-20 opacity-0 transition-all duration-300 bg-white border-l-4 border-tvm-orange text-slate-900 px-5 py-4 rounded-xl shadow-2xl flex items-center gap-3">
        <span id="toast-icon" class="text-tvm-orange">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </span>
        <span id="toast-message" class="text-sm font-semibold">Notificación</span>
    </div>

    <!-- Mosaico Decorativo Superior en el Header (Inspirado en la franja pixelada) -->
    <div class="w-full h-2.5 flex">
        <div class="flex-grow bg-emerald-500"></div>
        <div class="flex-grow bg-yellow-400"></div>
        <div class="flex-grow bg-orange-500"></div>
        <div class="flex-grow bg-pink-500"></div>
        <div class="flex-grow bg-purple-600"></div>
        <div class="flex-grow bg-blue-500"></div>
        <div class="flex-grow bg-slate-400"></div>
        <div class="flex-grow bg-yellow-500"></div>
        <div class="flex-grow bg-rose-500"></div>
    </div>

    <!-- Header Principal (Estilo Limpio e Institucional) -->
    <header class="sticky top-0 z-40 w-full border-b border-stone-200 bg-white/90 backdrop-blur-md shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex flex-col sm:flex-row items-center justify-between gap-4 py-2">
            <!-- Logo y Marca -->
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 border border-slate-300 p-0.5 bg-white flex flex-wrap items-center justify-center content-center gap-0.5 overflow-hidden shadow-sm">
                    <!-- Mini mosaico imitando el logo del cartel -->
                    <div class="w-3 h-3 bg-emerald-500"></div>
                    <div class="w-3 h-3 bg-yellow-400"></div>
                    <div class="w-3 h-3 bg-orange-500"></div>
                    <div class="w-3 h-3 bg-pink-500"></div>
                </div>
                <div>
                    <h1 class="text-lg sm:text-xl font-black text-slate-900 tracking-tight">
                        <span class="text-slate-600 font-light">VNIVERSITAT <span class="serif-title italic text-sm font-normal">ID</span> VALÈNCIA</span>
                        <span class="block text-xs font-bold uppercase tracking-widest text-slate-400 mt-0.5">#tvmorfosis</span>
                    </h1>
                </div>
            </div>
            
            <!-- Navegación Estilo Editorial -->
            <nav class="flex space-x-1 bg-stone-100 p-1.5 rounded-xl border border-stone-200">
                <button onclick="changeTab('inicio')" id="nav-inicio" class="px-4 py-2 text-xs sm:text-sm font-bold rounded-lg transition-all bg-white text-slate-900 shadow-sm">
                    Inicio
                </button>
                <button onclick="changeTab('programa')" id="nav-programa" class="px-4 py-2 text-xs sm:text-sm font-bold rounded-lg transition-all text-slate-500 hover:text-slate-900">
                    Programa
                </button>
                <button onclick="changeTab('favoritos')" id="nav-favoritos" class="px-4 py-2 text-xs sm:text-sm font-bold rounded-lg transition-all text-slate-500 hover:text-slate-900 flex items-center gap-1.5">
                    Mi Agenda
                    <span id="fav-badge" class="hidden bg-tvm-orange text-white text-[10px] px-2 py-0.5 rounded-full font-extrabold">0</span>
                </button>
                <button onclick="changeTab('asistente')" id="nav-asistente" class="px-4 py-2 text-xs sm:text-sm font-bold rounded-lg transition-all text-slate-500 hover:text-slate-900 flex items-center gap-1.5">
                    Asistente IA
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                    </span>
                </button>
            </nav>
        </div>
    </header>

    <!-- Contenedor Principal con la Franja Decorativa Lateral en Escritorios -->
    <div class="flex-grow max-w-7xl w-full mx-auto flex">
        
        <!-- Franja de Píxeles de Colores (Diseño ID de la Imagen - Solo visible en pantallas medianas y grandes) -->
        <aside class="hidden lg:flex flex-col w-12 flex-shrink-0 border-r border-stone-200 bg-white items-center py-6 gap-0.5 select-none relative overflow-hidden">
            <!-- Bloques de Mosaico de Colores en degradados desestructurados como en el folleto -->
            <div class="w-8 h-8 bg-emerald-400/80"></div>
            <div class="w-8 h-8 bg-emerald-500"></div>
            <div class="w-8 h-8 bg-green-600"></div>
            <div class="w-8 h-8 bg-lime-400"></div>
            <div class="w-8 h-8 bg-yellow-300"></div>
            <div class="w-8 h-8 bg-yellow-400"></div>
            <div class="w-8 h-8 bg-amber-400"></div>
            <div class="w-8 h-8 bg-orange-400"></div>
            <div class="w-8 h-8 bg-orange-500"></div>
            <div class="w-8 h-8 bg-red-400"></div>
            <div class="w-8 h-8 bg-pink-500"></div>
            <div class="w-8 h-8 bg-pink-600"></div>
            <div class="w-8 h-8 bg-purple-500"></div>
            <div class="w-8 h-8 bg-indigo-600"></div>
            <div class="w-8 h-8 bg-slate-400"></div>
            <div class="w-8 h-8 bg-slate-300"></div>
            <div class="w-8 h-8 bg-stone-100"></div>
            <!-- Elemento flotante decorativo -->
            <div class="absolute bottom-10 w-4 h-4 bg-yellow-400 rotate-45 transform"></div>
            <div class="absolute bottom-20 w-3 h-3 bg-rose-500 rotate-12 transform"></div>
        </aside>

        <!-- Contenido Central -->
        <main class="flex-grow px-4 sm:px-6 lg:px-8 py-8">
            
            <!-- ================= SECCIÓN INICIO ================= -->
            <section id="tab-inicio" class="space-y-12">
                
                <!-- Hero Section - Estilo Cartel (Fondo blanco, rombos flotantes y tipografía elegante) -->
                <div class="relative rounded-3xl border border-stone-200 bg-white p-6 sm:p-10 lg:p-12 overflow-hidden shadow-sm">
                    <!-- Rombos de Colores Flotantes del Cartel -->
                    <div class="absolute top-8 right-12 w-6 h-6 bg-slate-800 rotate-45 opacity-80 hidden md:block"></div>
                    <div class="absolute bottom-12 right-24 w-8 h-8 bg-yellow-400 rotate-45 opacity-80 hidden md:block"></div>
                    <div class="absolute top-1/2 right-4 w-4 h-4 bg-rose-500 rotate-45 opacity-80 hidden md:block"></div>
                    <div class="absolute top-20 right-48 w-5 h-5 bg-sky-400 rotate-12 opacity-65 hidden md:block"></div>

                    <div class="max-w-3xl relative z-10 space-y-6">
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 text-xs font-bold bg-amber-400/10 text-amber-700 rounded-full border border-amber-400/20">
                            <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
                            Edición Especial Práctica y Aplicada
                        </span>
                        
                        <h2 class="serif-title text-4xl sm:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
                            Documentación e <br>
                            <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-600 via-pink-600 to-indigo-600">Inteligencia Artificial</span>
                        </h2>

                        <!-- Subtítulo tipo cartel -->
                        <div class="border-y border-stone-200 py-3 my-2">
                            <p class="text-slate-500 font-bold tracking-widest text-xs uppercase">
                                JORNADAS DE REFLEXIÓN AUDIOVISUAL • UNIVERSITAT DE VALÈNCIA
                            </p>
                        </div>
                        
                        <p class="text-slate-600 text-sm sm:text-lg max-w-2xl leading-relaxed">
                            El debate global de la IA suele ser abstracto. En esta edición de <strong>TVmorfosis València</strong>, abrimos la caja de herramientas de las redacciones para analizar soluciones prácticas y reales que ya están operativas en la producción audiovisual actual. No teorizamos; analizamos lo que ya funciona.
                        </p>
                        
                        <div class="flex flex-wrap gap-4 pt-4">
                            <button onclick="changeTab('programa')" class="px-6 py-3 bg-slate-900 hover:bg-slate-800 text-white font-bold text-sm rounded-xl transition shadow-md flex items-center gap-2">
                                Explorar el Programa
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </button>
                            <button onclick="changeTab('asistente')" class="px-6 py-3 bg-stone-100 hover:bg-stone-200 text-slate-700 font-bold text-sm rounded-xl transition border border-stone-200 flex items-center gap-2">
                                Consultar Asistente IA
                            </button>
                        </div>
                    </div>
                </div>

                <!-- 4 Ámbitos Críticos en Formato Fichas de Archivo -->
                <div class="space-y-6">
                    <div class="text-center sm:text-left">
                        <h3 class="serif-title text-2xl sm:text-3xl font-bold text-slate-900">Cuatro pilares de la jornada</h3>
                        <p class="text-slate-500 text-xs sm:text-sm mt-1">Sistemas de análisis real del ecosistema audiovisual contemporáneo.</p>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                        <!-- Ámbito 1 -->
                        <div class="p-6 rounded-2xl border border-stone-200 bg-white hover:border-slate-400 transition duration-300 relative overflow-hidden group">
                            <div class="absolute top-0 left-0 w-2 h-full bg-pink-500"></div>
                            <div class="w-10 h-10 rounded-lg bg-pink-500/10 text-pink-600 flex items-center justify-center mb-4 group-hover:scale-110 transition duration-300">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                            </div>
                            <h4 class="font-extrabold text-slate-900 mb-2">1. Redacción y Contenidos</h4>
                            <p class="text-slate-500 text-xs leading-relaxed">Automatización práctica de escaletas, redacción de borradores y adaptación de formatos de emisión.</p>
                        </div>
                        <!-- Ámbito 2 -->
                        <div class="p-6 rounded-2xl border border-stone-200 bg-white hover:border-slate-400 transition duration-300 relative overflow-hidden group">
                            <div class="absolute top-0 left-0 w-2 h-full bg-amber-400"></div>
                            <div class="w-10 h-10 rounded-lg bg-amber-400/10 text-amber-600 flex items-center justify-center mb-4 group-hover:scale-110 transition duration-300">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            </div>
                            <h4 class="font-extrabold text-slate-900 mb-2">2. Investigación de Temas</h4>
                            <p class="text-slate-500 text-xs leading-relaxed">Estrategias de cribado de Big Data y scraping informático para identificar nuevas historias periodísticas.</p>
                        </div>
                        <!-- Ámbito 3 -->
                        <div class="p-6 rounded-2xl border border-stone-200 bg-white hover:border-slate-400 transition duration-300 relative overflow-hidden group">
                            <div class="absolute top-0 left-0 w-2 h-full bg-emerald-500"></div>
                            <div class="w-10 h-10 rounded-lg bg-emerald-500/10 text-emerald-600 flex items-center justify-center mb-4 group-hover:scale-110 transition duration-300">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                            </div>
                            <h4 class="font-extrabold text-slate-900 mb-2">3. Verificación de Datos</h4>
                            <p class="text-slate-500 text-xs leading-relaxed">Fact-checking automatizado frente a deepfakes, desinformación visual y manipulación mediática.</p>
                        </div>
                        <!-- Ámbito 4 -->
                        <div class="p-6 rounded-2xl border border-stone-200 bg-white hover:border-slate-400 transition duration-300 relative overflow-hidden group">
                            <div class="absolute top-0 left-0 w-2 h-full bg-indigo-600"></div>
                            <div class="w-10 h-10 rounded-lg bg-indigo-600/10 text-indigo-600 flex items-center justify-center mb-4 group-hover:scale-110 transition duration-300">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"></path></svg>
                            </div>
                            <h4 class="font-extrabold text-slate-900 mb-2">4. Documentación y Archivo</h4>
                            <p class="text-slate-500 text-xs leading-relaxed">Catalogación desasistida, visión por computador y transcripciones para explotar repositorios históricos.</p>
                        </div>
                    </div>
                </div>

                <!-- Entidades Organizadoras con un diseño institucional limpio -->
                <div class="rounded-2xl border border-stone-200 bg-white p-6 flex flex-col md:flex-row items-center justify-between gap-6">
                    <div class="space-y-1">
                        <h4 class="serif-title text-xl font-bold text-slate-900">Organización Académica e Internacional</h4>
                        <p class="text-slate-500 text-xs sm:text-sm">Una alianza entre la educación universitaria y el tejido industrial y cultural de Iberoamérica.</p>
                    </div>
                    <div class="flex items-center flex-wrap gap-4">
                        <div class="px-5 py-3 bg-stone-50 rounded-xl border border-stone-200 min-w-[160px] text-center">
                            <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-widest">Sede Oficial</span>
                            <span class="text-slate-800 font-extrabold text-sm">Universitat de València</span>
                        </div>
                        <div class="px-5 py-3 bg-stone-50 rounded-xl border border-stone-200 min-w-[160px] text-center">
                            <span class="block text-[10px] text-slate-400 font-bold uppercase tracking-widest">Red Televisiva</span>
                            <span class="text-slate-800 font-extrabold text-sm">ATEI</span>
                        </div>
                    </div>
                </div>
            </section>


            <!-- ================= SECCIÓN PROGRAMA (Estilo Folleto de la Imagen) ================= -->
            <section id="tab-programa" class="space-y-6 hidden">
                <!-- Controles de Filtros y Buscador -->
                <div class="flex flex-col sm:flex-row gap-4 items-center justify-between bg-white p-4 rounded-2xl border border-stone-200 shadow-sm">
                    <div class="flex flex-wrap gap-2 w-full sm:w-auto">
                        <button onclick="filterAgenda('all')" id="btn-filter-all" class="px-4 py-2 text-xs font-bold rounded-lg bg-slate-900 text-white transition">Todas las Sesiones</button>
                        <button onclick="filterAgenda('morning')" id="btn-filter-morning" class="px-4 py-2 text-xs font-bold rounded-lg bg-stone-100 text-slate-600 hover:text-slate-900 transition">Mañana</button>
                        <button onclick="filterAgenda('afternoon')" id="btn-filter-afternoon" class="px-4 py-2 text-xs font-bold rounded-lg bg-stone-100 text-slate-600 hover:text-slate-900 transition">Tarde</button>
                    </div>
                    <!-- Buscador -->
                    <div class="relative w-full sm:w-72">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        </div>
                        <input type="text" id="search-input" oninput="searchAgenda()" placeholder="Buscar en el programa..." class="w-full bg-stone-50 border border-stone-200 rounded-xl pl-9 pr-4 py-2 text-xs text-slate-800 placeholder-slate-400 focus:outline-none focus:border-slate-500 transition">
                    </div>
                </div>

                <!-- Contenedor del Listado del Programa -->
                <div id="agenda-list" class="space-y-4">
                    <!-- Se inyecta dinámicamente mediante JS -->
                </div>
            </section>


            <!-- ================= SECCIÓN MI AGENDA (FAVORITOS) ================= -->
            <section id="tab-favoritos" class="space-y-6 hidden">
                <div class="bg-white p-6 rounded-2xl border border-stone-200 space-y-2 shadow-sm">
                    <h3 class="serif-title text-2xl font-bold text-slate-900">Mi Agenda Personalizada</h3>
                    <p class="text-slate-500 text-xs sm:text-sm">Conserva aquí las ponencias a las que tienes pensado asistir en directo en el taller de audiovisuales de la Universitat de València.</p>
                </div>

                <div id="favorites-list" class="space-y-4">
                    <!-- Inyección dinámica -->
                </div>
            </section>


            <!-- ================= SECCIÓN ASISTENTE IA ================= -->
            <section id="tab-asistente" class="space-y-6 hidden">
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <!-- Columna Izquierda: Información -->
                    <div class="lg:col-span-1 bg-white border border-stone-200 p-6 rounded-2xl space-y-6 shadow-sm">
                        <div>
                            <span class="inline-block px-2.5 py-1 text-[10px] bg-emerald-100 text-emerald-800 rounded border border-emerald-200 font-extrabold mb-2">AGENTE LOCAL</span>
                            <h3 class="serif-title text-xl font-bold text-slate-900">Asistente de Consulta TVmorfosis</h3>
                            <p class="text-slate-500 text-xs mt-1 leading-relaxed">
                                Resuelve tus dudas sobre los ponentes, las mesas redondas, los horarios e implementaciones prácticas en tiempo real.
                            </p>
                        </div>
                        
                        <div class="space-y-3">
                            <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest">Preguntas sugeridas:</h4>
                            <div class="space-y-2">
                                <button onclick="askBot('¿Qué se habla sobre verificación o fake news?')" class="w-full text-left text-xs bg-stone-50 hover:bg-stone-100 border border-stone-200 hover:border-slate-300 text-slate-700 p-3 rounded-xl transition font-medium">
                                    "¿Qué se habla sobre verificación?"
                                </button>
                                <button onclick="askBot('Háblame sobre la mesa de televisiones locales')" class="w-full text-left text-xs bg-stone-50 hover:bg-stone-100 border border-stone-200 hover:border-slate-300 text-slate-700 p-3 rounded-xl transition font-medium">
                                    "Háblame sobre la mesa de proximidad"
                                </button>
                                <button onclick="askBot('¿Cuál es el enfoque de la mesa de ingeniería de la tarde?')" class="w-full text-left text-xs bg-stone-50 hover:bg-stone-100 border border-stone-200 hover:border-slate-300 text-slate-700 p-3 rounded-xl transition font-medium">
                                    "¿De qué trata la última mesa?"
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Columna Derecha: Chat Interactivo -->
                    <div class="lg:col-span-2 border border-stone-200 bg-white rounded-2xl flex flex-col h-[500px] shadow-sm overflow-hidden">
                        <!-- Encabezado del chat -->
                        <div class="p-4 border-b border-stone-200 bg-stone-50 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></div>
                                <span class="text-xs font-bold text-slate-800">Asistente Virtual del Dossier</span>
                            </div>
                            <button onclick="clearChat()" class="text-slate-400 hover:text-slate-700 text-xs font-bold">Limpiar chat</button>
                        </div>

                        <!-- Mensajes del chat -->
                        <div id="chat-messages" class="flex-grow p-4 overflow-y-auto space-y-4 bg-stone-50/40">
                            <!-- Mensaje de bienvenida -->
                            <div class="flex gap-3 max-w-[85%]">
                                <div class="w-8 h-8 rounded-lg bg-slate-900 text-white flex items-center justify-center flex-shrink-0 text-xs font-bold shadow-sm">
                                    TV
                                </div>
                                <div class="bg-white border border-stone-200 text-slate-700 px-4 py-3 rounded-2xl rounded-tl-none text-xs sm:text-sm shadow-sm leading-relaxed">
                                    ¡Hola! Soy el asistente virtual de TVmorfosis València. Estoy preparado para ayudarte a navegar por el programa práctico. ¿Qué te gustaría saber sobre los horarios, mesas de debate, la inauguración o los participantes de este encuentro?
                                </div>
                            </div>
                        </div>

                        <!-- Entrada del chat -->
                        <div class="p-4 border-t border-stone-200 bg-white">
